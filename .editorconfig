# EditorConfig helps maintain consistent coding styles across different editors
# See https://editorconfig.org for details

root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false  # Preserve trailing spaces in markdown

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2
