digraph roadmap {
    rankdir=TB;
    node[shape=box,style="rounded,filled",fillcolor="#e8f4e8"];

    complete[label="Phases 0-9 COMPLETE",style="filled,bold"];

    p0[label="Phase 0: Skeleton"];
    p1[label="Phase 1: Benchmarks"];
    p2[label="Phase 2: Device scan"];
    p3[label="Phase 3: TUI core"];
    p4[label="Phase 4: Charts"];
    p5[label="Phase 5: Test modes"];
    p6[label="Phase 6: CLI args"];
    p7[label="Phase 7: Clippy"];
    p8[label="Phase 8: Golden tests"];
    p9[label="Phase 9: Perf opt"];

    future[label="Future: Deferred items",style="filled",fillcolor="#f4e8e8"];
    async_io[label="Phase 9C: Async I/O"];
    smart[label="SMART integration"];
    memtest[label="MemTest screen"];
    report_screen[label="Report screen"];
    packaging[label="Packaging\n(deb/rpm)"];
    ci[label="CI/CD for tests"];

    complete -> p0 -> p1 -> p2 -> p3 -> p4 -> p5 -> p6 -> p7 -> p8 -> p9;
    p9 -> future;
    future -> async_io;
    future -> smart;
    future -> memtest;
    future -> report_screen;
    future -> packaging;
    future -> ci;
}
